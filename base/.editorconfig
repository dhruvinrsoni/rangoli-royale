# EditorConfig — consistent coding style across editors and IDEs
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{java,kt,kts,gradle}]
indent_size = 4

[*.py]
indent_size = 4

[*.{cmd,bat,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab
