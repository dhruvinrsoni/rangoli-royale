<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{PROJECT_NAME}}</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header>
    <h1>{{PROJECT_NAME}}</h1>
    <p>A collection of independent nano-applications</p>
  </header>

  <main id="app-grid"></main>

  <script src="app_registry.js"></script>
  <script>
    const grid = document.getElementById('app-grid');
    (window.APP_REGISTRY || []).forEach(app => {
      const card = document.createElement('a');
      card.href = app.path;
      card.className = 'app-card';
      card.innerHTML = `
        <div class="app-code">${app.shortCode}</div>
        <h2>${app.name}</h2>
        <p>${app.description}</p>
        <div class="tags">${app.tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>
      `;
      grid.appendChild(card);
    });
  </script>
</body>
</html>
